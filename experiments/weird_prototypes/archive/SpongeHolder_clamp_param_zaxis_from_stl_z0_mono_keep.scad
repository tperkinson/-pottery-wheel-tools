// Sweep parameters (Y-axis sweep; axis line at X=axis_x, Z=axis_z)
sweep_angle = 45;
use_radius = true;
radius = 222.29;
axis_z = 0;

// Clean math: use the rightmost point as the radius reference.
// Axis is set so that max X of the profile sits on the radius.
max_profile_x = max([for (p = profile_points) p[0]]);
min_profile_x = min([for (p = profile_points) p[0]]);

axis_x_manual = 0;  // used when use_radius = false
axis_x = use_radius ? (max_profile_x - radius) : axis_x_manual;

// Keep rotate_extrude happy: ensure all X are >= 0 after shifting by axis_x.
axis_shift_x = max(0, axis_x - min_profile_x + 0.1);

module raw_profile() {
    polygon(points=profile_points);
}

module clamp_profile() {
    translate([axis_shift_x, 0])
        translate([-axis_x, -axis_z])
            raw_profile();
}

if (show_profile) {
    clamp_profile();
    if (show_axis) {
        color("red")
            translate([axis_shift_x, 0])
                circle(r=axis_marker_r, $fn=48);
    }
} else {
    rotate([90,0,0])
        rotate_extrude(angle=sweep_angle)
            clamp_profile();
}
